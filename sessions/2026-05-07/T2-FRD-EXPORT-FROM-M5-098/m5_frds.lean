-- ============================================================
-- B1.  V_quad family (5-parameter rational tuple)
-- ============================================================

/--
The 5-parameter family of degree-two PCFs in SIARC F(2,4) convention,
with `a` of degree 2 in the index and `b` of degree 1.

  a(n) = a2 * n^2 + a1 * n + a0
  b(n) = b1 * n + b0

Substrate anchors:
  picture_v1.19.md line 919  (M5 milestone row "V_quad -> P_III(D_6)")
  PCF-1 v1.3       § 1.1     (transcendence predicate; d=2 class
                              equation labelled `eq:d2-class`)

The label `VQuad` denotes the parameter manifold; concrete strata
(Trans / Alg / Rat / Log) are carved out via `stratumOf` (B4).
-/
structure VQuad where
  a2 : ℚ
  a1 : ℚ
  a0 : ℚ
  b1 : ℚ
  b0 : ℚ
deriving Repr, DecidableEq

namespace VQuad

/--
Polynomial evaluation of `a` at a rational index `n`, per the
leading-first convention `a(n) = a2 n^2 + a1 n + a0`.
-/
def aPoly (V : VQuad) (n : ℚ) : ℚ := V.a2 * n^2 + V.a1 * n + V.a0

/--
Polynomial evaluation of `b` at a rational index `n`, per the
leading-first convention `b(n) = b1 n + b0`.
-/
def bPoly (V : VQuad) (n : ℚ) : ℚ := V.b1 * n + V.b0

end VQuad

-- ============================================================
-- B2.  R(h) ratio
-- ============================================================

/--
Stratum tag for the d=2 PCF transcendence dichotomy. Mirrors the
3-stratum partition refined in picture_v1.19.md lines 295-298
(neg-rational `a_1`, pos-rational `a_1`, `a_1 = 0`) plus the Trans
side recorded in PCF-1 v1.3 § 4 Table 1 (`tab:dichotomy`).

Members:
  * `trans`   — Delta > 0 Trans stratum (e.g. F(2,4) Trans table)
  * `alg`     — algebraic non-rational stratum
  * `rat`     — rational stratum
  * `log`     — logarithmic stratum (e.g. ln 2 family)
  * `phantom` — phantom / unclassified residual stratum
-/
inductive Stratum where
  | trans
  | alg
  | rat
  | log
  | phantom
deriving Repr, DecidableEq

/--
Pointwise ratio `R(h) = b(h) / a(h)` at a rational parameter `h`.

Substrate anchors:
  picture_v1.19.md lines 295-298  (3-stratum partition at 60+ digits)
  PCF-1 v1.3       § 1.1 lines 109-116  (PCF schema; ratio interpretation)

Convention note: branching by stratum is captured separately by
`stokes` (B4). The bare ratio `R` is total over rationals where
`aPoly h ≠ 0`; the `aPoly h = 0` case is left to a subsequent fire
(see `discrepancy_log.json` D-D2 partial-function audit).
-/
def R (V : VQuad) (h : ℚ) : ℚ := V.bPoly h / V.aPoly h

-- ============================================================
-- B3.  Indicial polynomial + double-root condition
-- ============================================================

/--
The indicial polynomial of the d=2 family is the leading-coefficient
polynomial in the Wallis recurrence, evaluated as a function `ℚ → ℚ`:

    indicialPoly V (u) = a2 * u^2 + a1 * u + a0

Substrate anchors:
  picture_v1.19.md line 91  (Wimp-Zeilberger Newton-polygon convention)
  PCF-1 v1.3       § 2.1    (Perron-Poincare characteristic eq:char;
                            balanced discriminant Delta = beta^2 - 4 alpha gamma
                            translates under the a <-> b label swap to the
                            indicial discriminant a1^2 - 4 a2 a0 used here)
-/
def indicialPoly (V : VQuad) (u : ℚ) : ℚ :=
  V.a2 * u^2 + V.a1 * u + V.a0

/--
Double-root condition for the indicial polynomial:

    a1^2 = 4 * a2 * a0

This is the algebraic locus where `indicialPoly V` has a double root,
equivalently where the indicial discriminant `a1^2 - 4 a2 a0` vanishes.
This locus is the SIARC analogue of the borderline case discussed in
picture_v1.19.md § G23 (lines 97-98) where the SIARC stratum sits at
the boundary between Wimp-Zeilberger normal and anormal cases.
-/
def doubleRootCondition (V : VQuad) : Prop :=
  V.a1^2 = 4 * V.a2 * V.a0

/--
The indicial discriminant of the d=2 family, equal to
`a1^2 - 4 * a2 * a0` and named in alignment with the balanced
discriminant `Delta = beta^2 - 4 alpha gamma` of PCF-1 v1.3
Definition 4.1 (`def:Delta`) under the a <-> b label swap.
-/
def indicialDiscriminant (V : VQuad) : ℚ :=
  V.a1^2 - 4 * V.a2 * V.a0

