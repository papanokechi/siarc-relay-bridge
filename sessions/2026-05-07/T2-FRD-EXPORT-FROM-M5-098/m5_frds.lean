-- ============================================================
-- B8.  Wallis recurrence
-- ============================================================

/--
One step of the Wallis recurrence

    p_n = b_n * p_{n-1} + a_n * p_{n-2}

with `b_n = bPoly V (n : ℚ)` and `a_n = aPoly V (n : ℚ)`. This is
the fundamental linear-recurrence engine of the d=2 PCF; the
convergent sequence `p_n / q_n` produces the value of the PCF.

Substrate anchors:
  picture_v1.19.md line 91     (Newton-polygon analysis convention)
  PCF-1 v1.3       § 2.1       (Wallis recurrence eq:wallis)
-/
def wallisStep (V : VQuad) (n : ℕ) (pPrev pPrev2 : ℚ) : ℚ :=
  V.bPoly (n : ℚ) * pPrev + V.aPoly (n : ℚ) * pPrev2

/--
Numerator sequence of the Wallis recurrence with seeds
`(p_{-1}, p_0) = (1, b_0)` per PCF-1 v1.3 § 1.1. The `n+2` body
is `sorry`; a subsequent fire (M10-PROOF-DRAFT or a Wallis-recurrence
discharge fire) populates it.
-/
def wallisP (V : VQuad) : ℕ → ℚ
  | 0 => V.b0
  | 1 => V.b1 + V.b0 * V.a1   -- placeholder; substantive at n+2 below
  | _ + 2 => sorry

