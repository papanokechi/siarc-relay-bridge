                  ordinary differential equations at an irregular
                  singular point. Cited in \Cref{q:sectorial} as
                  one of the four candidate routes to the
                  sectorial upgrade.}
}

@article{immink1984asymptotics,
  author       = {Immink, G. K.},
  title        = {Asymptotics of analytic difference equations},
  journal      = {Lecture Notes in Mathematics},
  volume       = {1085},
  publisher    = {Springer},
  year         = {1984},
  annote       = {B. The modern reference for the
                  Borel-summability of formal solutions of analytic
                  difference equations at irregular singular points
                  of fractional rank. Not acquired at the time of
                  preparation of the present note. Cited in
