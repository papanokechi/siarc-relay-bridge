@article{birkhoff_trjitzinsky_1933,
  author    = {Birkhoff, George D. and Trjitzinsky, Waldemar J.},
  title     = {Analytic theory of singular difference equations},
  journal   = {Acta Mathematica},
  volume    = {60},
  year      = {1933},
  pages     = {1--89},
  doi       = {10.1007/BF02398269},
  publisher = {Institut Mittag-Leffler},
  annote    = {B. Primary literature anchor. \S1 specifies the
               coefficient-of-the-right-kind hypothesis;
               \S\S 7--9 give the Theorem~II / Lemma~10 /
               Fundamental Theorem chain establishing existence
               and factorization of completely-proper formal
               solutions in each Stokes quadrant; \S11 Theorem~III
               gives the converse / sectorial-realization. PDF
               SHA-$256$ \texttt{dcd7e3c6b2a12ae1ce917d322763ff9dde5ec69ab5f23080d043699822d68fe6}
               anchored at
               \texttt{tex/submitted/control center/literature/g3b\_2026-05-03/}.}
}

@book{wimp1984computation,
  author    = {Wimp, Jet},
  title     = {Computation with recurrence relations},
  publisher = {Pitman},
  address   = {Boston},
  year      = {1984},
  annote    = {B. Standard reference for the asymptotic analysis
               of linear recurrences. The Wimp--Zeilberger
               normal-case ansatz of \Cref{sec:wz-ansatz-intro}
               (equation \eqref{eq:wz-ansatz}) is \S6, with the
               normal / borderline / anormal case distinction
               \S5--\S6. The borderline-case condition
               $\dega = 2\degb$ used in
               \Cref{sec:gap-wz-border} is the threshold between
               the normal and borderline cases of \S5.}
}

@article{birkhoff1930formal,
  author       = {Birkhoff, George D.},
  title        = {Formal theory of irregular linear difference
                  equations},
  journal      = {Acta Mathematica},
  volume       = {54},
  pages        = {205--246},
  year         = {1930},
  doi          = {10.1007/BF02547522},
  annote       = {B. The 1930 formal-theory paper companion to
                  \cite{birkhoff_trjitzinsky_1933}. Section~2
                  establishes uniformly that any $n \times n$
                  linear system at an irregular singular point of
                  rank $q$ admits a formal series solution; the
                  Borel-summability content is treated in
                  \cite{birkhoff_trjitzinsky_1933}, not here.
                  Cited in \Cref{q:sectorial} as the formal-side
                  half of the sectorial-upgrade chain.}
}

@book{wasow1965asymptotic,
  author       = {Wasow, Wolfgang},
  title        = {Asymptotic Expansions for Ordinary Differential
                  Equations},
  publisher    = {Interscience Publishers, John Wiley \& Sons
                  (Reprint: Dover, 1987)},
  year         = {1965},
  series       = {Pure and Applied Mathematics, Vol.~XIV},
  annote       = {B. Section~X.3 (Theorem~11.1) supplies the
                  formal-to-analytic sectorial-asymptotic existence
                  theorem at an irregular singular point of integer
                  rank $q$. The Wasow~\S X.3 PDF on disk at the time
                  of preparation of the present note is image-only
                  (no OCR), and is the first acquisition target of
                  any T1 Phase~3 follow-on. Cited in
                  \Cref{q:sectorial}.}
}

@article{adams1928analytic,
  author       = {Adams, Charles Raymond},
  title        = {On the irregular cases of the linear ordinary
                  difference equation},
  journal      = {Transactions of the American Mathematical Society},
  volume       = {30},
  number       = {3},
  pages        = {507--541},
  year         = {1928},
  doi          = {10.1090/S0002-9947-1928-1501439-2},
  annote       = {B. The original 1928 sectorial-asymptotic
                  analysis of the irregular singular case for
                  linear ordinary difference equations. NIA on disk
                  at the time of preparation per the upstream A-01
                  verdict of \cite{siarc_t1_phase2}; the original
                  Adams argument is transitively covered, for the
                  purposes of the present note's formal-level
                  baseline, by Birkhoff--Trjitzinsky 1933~\S\S 7--9.
                  Cited in \Cref{q:sectorial}.}
}

@article{turrittin1955convergent,
  author       = {Turrittin, H. L.},
  title        = {Convergent solutions of ordinary linear
                  homogeneous differential equations in the
                  neighborhood of an irregular singular point},
  journal      = {Acta Mathematica},
  volume       = {93},
  pages        = {27--66},
  year         = {1955},
  doi          = {10.1007/BF02392519},
  annote       = {B. Modern Borel-Laplace formalisation of the
