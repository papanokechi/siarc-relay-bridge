  annote    = {A. Reference text for the Borel--Laplace channel.
               Ch.~3 (formal series, Gevrey-$1$ classes) defines the
               function space $D$ that we identify with the
               L(t)-channel target; Ch.~5 (resurgence) supplies the
               trans-series template used in our Borel-of-trans-series
               channel definition.}
}

