@book{wasow1965asymptotic,
  author       = {Wasow, Wolfgang},
  title        = {Asymptotic Expansions for Ordinary Differential Equations},
  year         = {1965},
  publisher    = {Interscience Publishers, John Wiley \& Sons (Reprint:
                  Dover, 1987)},
  series       = {Pure and Applied Mathematics, Vol.~XIV},
  note         = {Chapter IV \S\S10--15 (distinct-eigenvalue case) and
                  Chapter V \S\S16--19 (general / multiple-eigenvalue
                  case) carry the Main Asymptotic Existence Theorem
                  uniformly in the irregular-singularity rank.
                  Theorem~12.1 (\S12, distinct case): for nonnegative
                  integer rank, the corresponding linear system has a
                  fundamental matrix solution analytic in any sector of
                  central angle bounded by a $1/(\mathrm{rank}+1)$
                  fraction of $\pi$, asymptotic to the formal solution.
                  Theorem~19.1 (\S19.5, general case): same conclusion
                  for any holomorphic coefficient matrix, with formal
                  solution carrying a Puiseux gauge.
                  Equation~(19.3) is the gauge form encoding the
                  Borel-singularity radius at the rank-$q$ irregular
                  singular point.}
}

