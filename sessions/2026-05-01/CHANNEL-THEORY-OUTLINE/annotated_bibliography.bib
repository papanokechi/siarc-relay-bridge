% Annotated bibliography for "Channel structure of asymptotic
% deformations in polynomial continued fraction dynamics".
%
% Relevance ratings appended in the annote field:
%   A: foundational  -- the outline cannot be stated without this
%   B: directly relevant -- explicit construction or worked example used
%   C: tangential / contextual -- background or analogy

% =====================================================================
% A. Borel-resummation and resurgence foundations
% =====================================================================

@book{costin2008asymptotics,
  author    = {Costin, Ovidiu},
  title     = {Asymptotics and {B}orel summability},
  series    = {Chapman \& Hall/CRC Monographs and Surveys in Pure and Applied Mathematics},
  volume    = {141},
  publisher = {CRC Press},
  address   = {Boca Raton, FL},
  year      = {2008},
  annote    = {A. Reference text for the Borel--Laplace channel.
               Ch.~3 (formal series, Gevrey-$1$ classes) defines the
               function space $D$ that we identify with the
               L(t)-channel target; Ch.~5 (resurgence) supplies the
               trans-series template used in our Borel-of-trans-series
               channel definition.}
}

@incollection{sauzin2014resurgent,
  author    = {Sauzin, David},
  title     = {Resurgent functions and splitting problems},
  booktitle = {RIMS K\^{o}ky\^{u}roku Bessatsu},
  volume    = {B40},
  year      = {2014},
  pages     = {197--250},
  annote    = {A. Singled out for the explicit treatment of the
               alien derivative and the relationship between
               formal-series sectorial sums and Stokes constants.
               The "splitting" perspective frames the bridge
               identity (Sec.~6) we conjecture between the Stokes
               exponent and Borel-singular structure.}
}

@book{mitschi2016divergent,
  author    = {Mitschi, Claude and Sauzin, David},
  title     = {Divergent series, summability and resurgence {I}: {M}onodromy and resurgence},
  series    = {Lecture Notes in Mathematics},
  volume    = {2153},
  publisher = {Springer},
  year      = {2016},
  doi       = {10.1007/978-3-319-28736-2},
  annote    = {A. Volume I of the trilogy. Used for the
               definition of multi-summability and the
               classification of Stokes phenomena that we adapt
               to PCF dynamics.}
}

@book{lodayrichaud2016divergent,
  author    = {Loday-Richaud, Mich\`ele},
  title     = {Divergent series, summability and resurgence {II}: {S}imple and multiple summability},
  series    = {Lecture Notes in Mathematics},
  volume    = {2154},
  publisher = {Springer},
  year      = {2016},
  doi       = {10.1007/978-3-319-29075-1},
  annote    = {A. Volume II. Ch.~7 (Stokes cocycles) is the
               structural template for the connection-coefficient
               channel.}
}

@book{delabaere2016divergent,
  author    = {Delabaere, \'Eric},
  title     = {Divergent series, summability and resurgence {III}: {R}esurgent methods and the first {P}ainlev\'e equation},
  series    = {Lecture Notes in Mathematics},
  volume    = {2155},
  publisher = {Springer},
  year      = {2016},
  doi       = {10.1007/978-3-319-29000-3},
  annote    = {B. Volume III worked-example template:
               trans-series + Borel resummation + connection
               formulae for $P_I$. Our Borel channel for V\_quad
               is the discrete analogue of Delabaere's continuous
               construction; the failure of the Pad\'e--Borel
               radius to stabilise (Session E) shows the
               difference equation case is more delicate.}
}

@article{ecalle1981fonctions,
  author    = {\'Ecalle, Jean},
  title     = {Les fonctions r\'esurgentes},
  journal   = {Publ. Math. Orsay},
  volume    = {81-05, 81-06, 85-05},
  year      = {1981--1985},
  annote    = {A. Origin of the resurgence formalism. Cited as
               the historical anchor for the alien-calculus
               treatment of the Borel channel.}
}

% =====================================================================
% B. Stokes / connection-coefficient / Painleve channel
% =====================================================================

@article{costincostin2001formation,
  author    = {Costin, O. and Costin, R. D.},
  title     = {On the formation of singularities of solutions of nonlinear differential systems in antiStokes directions},
  journal   = {Invent. Math.},
  volume    = {145},
  number    = {3},
  year      = {2001},
  pages     = {425--485},
  doi       = {10.1007/s002220100153},
  annote    = {A. Formal proof that singularity locations of
               trans-series solutions are encoded in Stokes
               constants. Underwrites the claim (Sec.~3) that
               the connection-coefficient channel and the
               Borel-of-trans-series channel are not independent
               at the level of analytic data, even when our
               numerical Pad\'e probes (Session E$'$) cannot
               extract that data.}
}

@book{iwasaki1991from,
  author    = {Iwasaki, Katsunori and Kimura, Hironobu and Shimomura, Shun and Yoshida, Masaaki},
  title     = {From {G}auss to {P}ainlev\'e: {A} modern theory of special functions},
  publisher = {Vieweg},
  address   = {Braunschweig},
  year      = {1991},
  annote    = {A. Ch.~6 (Stokes constants for Painlev\'e
               transcendents) gives the connection-coefficient
               channel for $P_{II}$--$P_{VI}$. The closed-form
               $P_{III}(D_6)$ parameters $(1/6,0,0,-1/2)$ that
               V\_quad realises are computed in this framework.}
}

@article{boalch2001stokes,
  author    = {Boalch, Philip},
  title     = {Stokes matrices, {P}oisson {L}ie groups and {F}robenius manifolds},
  journal   = {Invent. Math.},
  volume    = {146},
  number    = {3},
  year      = {2001},
  pages     = {479--506},
  doi       = {10.1007/s002220100170},
  annote    = {B. Stokes-matrix moduli supply the candidate
               structure for the channel space (op:channel-moduli).
               If the channel functor $\chi$ has a moduli interpretation
               at all, Boalch's framework is where it must live.}
}

@article{jimbomiwa1981monodromy,
